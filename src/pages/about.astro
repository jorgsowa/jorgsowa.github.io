---
import Base from '../layouts/Base.astro';

const description = 'Open Source, Open Tech, and DIY enthusiast. Contributing to PHP Core, static analysis tools like Psalm and PHPStan, and security tools.';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Jorg Sowa",
  "url": "https://jorgsowa.github.io",
  "email": "jorg.sowa@gmail.com",
  "sameAs": ["https://github.com/jorgsowa"],
  "description": description,
};
---
<Base title="About — Jorg Sowa" description={description} ogType="profile" jsonLd={jsonLd}>
  <p class="section-label">About</p>
  <article>
    <h1>Hi there, wanderer 👋</h1>

    <p>I'm an Open Source, Open Tech, and Open Source DIY enthusiast.</p>

    <p>Interested in contributing to the:</p>
    <ul>
      <li>PHP Core 🐘</li>
      <li>Static Analysis tools (such as <a href="https://github.com/jorgsowa/mir">Mir</a>, Psalm, PHPStan)</li>
      <li>Security tools, and strengthening the OS ecosystem security</li>
    </ul>

    <p>You can reach out to me: <a href="mailto:jorg.sowa@gmail.com">jorg.sowa@gmail.com</a></p>
  </article>
</Base>
