---
interface Props {
  title: string;
  description?: string;
  showProgress?: boolean;
  ogType?: 'website' | 'article' | 'profile';
  articleMeta?: { publishedTime: string; author: string };
  jsonLd?: object;
}

const {
  title,
  description,
  showProgress = false,
  ogType = 'website',
  articleMeta,
  jsonLd,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteName = 'Jorg Sowa';
const siteDescription = 'Open Source, Open Tech, and DIY enthusiast. Writing about PHP, static analysis, and software security.';

const path = Astro.url.pathname;
const writingActive = path === '/' || path.startsWith('/posts');
const aboutActive   = path === '/about' || path === '/about/';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  {description && <meta name="description" content={description}>}
  <meta name="author" content="Jorg Sowa">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href={canonicalURL}>

  <!-- Open Graph -->
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description ?? siteDescription}>
  <meta property="og:type" content={ogType}>
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:site_name" content={siteName}>
  {ogType === 'article' && articleMeta && (
    <>
      <meta property="article:published_time" content={articleMeta.publishedTime}>
      <meta property="article:author" content={articleMeta.author}>
    </>
  )}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description ?? siteDescription}>

  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

  <script is:inline>try{if(localStorage.getItem('theme')==='dark')document.documentElement.setAttribute('data-theme','dark')}catch(e){}</script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;1,6..72,400;1,6..72,500&family=Spectral:ital,wght@0,400;0,500;1,400;1,500&family=JetBrains+Mono:wght@400;500&display=swap">
  <link rel="stylesheet" href="/styles/global.css">
</head>
<body>
  {showProgress && <div class="progress-bar" id="progress-bar"></div>}
  <div class="layout">
    <header class="site-header">
      <div class="header-left">
        <a href="/" class="wordmark">
          <svg class="logo-emblem" width="8" height="8" viewBox="0 0 12 12" fill="none" aria-hidden="true" shape-rendering="geometricPrecision">
            <path d="M6 0.5L11.5 6L6 11.5L0.5 6Z" fill="currentColor"/>
          </svg>Jorg Sowa
        </a>
        <nav>
          <a href="/" class:list={[{ active: writingActive }]}>Writing</a>
          <a href="/about" class:list={[{ active: aboutActive }]}>About</a>
        </nav>
      </div>
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
        <span class="theme-icon"></span>
      </button>
    </header>

    <main>
      <slot />

      <footer class="site">
        <div>&copy; 2026 Jorg Sowa.</div>
        <div class="links">
          <a href="https://github.com/jorgsowa">GitHub</a>
          <a href="mailto:jorg.sowa@gmail.com">Email</a>
        </div>
      </footer>
    </main>
  </div>

  <script is:inline>
    (function () {
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          document.documentElement.classList.add('transitions-ready');
        });
      });
      var toggle = document.getElementById('theme-toggle');
      if (toggle) {
        toggle.addEventListener('click', function () {
          var html = document.documentElement;
          var next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
          html.setAttribute('data-theme', next);
          try { localStorage.setItem('theme', next); } catch (e) {}
        });
      }
      var bar = document.getElementById('progress-bar');
      if (bar) {
        window.addEventListener('scroll', function () {
          var d = document.documentElement;
          var pct = d.scrollTop / (d.scrollHeight - d.clientHeight) * 100;
          bar.style.width = Math.min(pct, 100) + '%';
        }, { passive: true });
      }
    })();
  </script>
</body>
</html>
